{
  "name": "flight-sim-fable5",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GCS-first deterministic 6-DOF flight simulator (browser sim + Node MAVLink bridge)",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "bridge": "node bridge/server.mjs",
    "check:gcs": "node tests/gcs-loop-check.mjs",
    "hils": "node tests/hils-run.mjs",
    "serve": "python3 -m http.server 8123",
    "check:browser": "node tests/browser-check.mjs",
    "plant": "node bridge/plant.mjs",
    "check:plant": "node tests/plant-check.mjs",
    "sitl": "node bridge/sitl.mjs",
    "check:sitl": "node tests/sitl-check.mjs",
    "coverage": "node tests/coverage-check.mjs"
  }
}